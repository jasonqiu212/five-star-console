# Appwrite Configuration
# Get these values from your Appwrite Console: https://cloud.appwrite.io/console

# Your Appwrite Project ID (found in Project Settings)
VITE_APPWRITE_PROJECT_ID=

# Your Appwrite Project Name
VITE_APPWRITE_PROJECT_NAME=

# Appwrite API Endpoint (use your region endpoint or self-hosted URL)
# Cloud regions: https://cloud.appwrite.io/v1 or https://sgp.cloud.appwrite.io/v1
VITE_APPWRITE_ENDPOINT=

# Your Appwrite Database ID
VITE_APPWRITE_DATABASE_ID=

# Your Appwrite order functions ID
VITE_APPWRITE_ORDER_FUNCTIONS_ID=
