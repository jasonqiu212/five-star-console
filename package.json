{
  "name": "five-star-console",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Five Star Console Monorepo",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "generate-appwrite-types": "appwrite pull tables && appwrite types -l ts packages/shared-types/src/appwrite",
    "dev:frontend": "pnpm --filter five-star-console-frontend dev",
    "dev:backend": "pnpm --filter five-star-console-backend dev",
    "build:frontend": "pnpm --filter five-star-console-frontend build",
    "build:backend": "pnpm --filter five-star-console-backend build",
    "build": "pnpm -r build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.21.0",
    "appwrite-cli": "16.0.0"
  }
}
